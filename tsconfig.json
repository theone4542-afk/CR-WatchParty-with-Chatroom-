{
  "compilerOptions": {
    "allowSyntheticDefaultImports": true,
    "esModuleInterop": true,
    "experimentalDecorators": true,
    "allowJs": true,
    "target": "ES2016",
    "module": "ESNext",
    "sourceMap": true,
    "strict": false,
    "alwaysStrict": true,
    "strictNullChecks": false,
    "outDir": "./build",
    "lib": ["ESNext", "WebWorker", "DOM"],
    "skipLibCheck": true,
    "types": ["chrome", "node"]
  },
  "include": [
    "./src/*"
  ]
}